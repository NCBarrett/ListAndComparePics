<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>
<VBox fx:id="root" alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.listandcomparepics.Controller">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Button fx:id="dirBrowser" text="Directory Browser"
            onAction="#onDirBrowserClick"/>
    <Label fx:id="dirChosen"/>

    <TextField fx:id="textRegEx"/>

    <HBox>
        <ListView fx:id="fileListView">

        </ListView>
        <ImageView fx:id="imageViewer"/>
    </HBox>

</VBox>
